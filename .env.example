# Tournament Arena — environment variables (copy to .env.local and fill in)

# --- Supabase ---
# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side ONLY. Never expose to the client. Used by /api/sync and scoring jobs.
SUPABASE_SERVICE_ROLE_KEY=

# --- Football data API ---
# Select the data provider: "football-data" (default) or "api-football".
FOOTBALL_PROVIDER=football-data

# football-data.org (default provider). Free key: https://www.football-data.org/client/register
# Server-side only.
FOOTBALL_DATA_API_KEY=
# Optional: World Cup competition code (default WC).
# FOOTBALL_DATA_COMPETITION=WC
# Optional: leave UNSET to use the current season (the live 2026 World Cup). On the
# free tier the season filter is restricted to the current season, so only set this
# to target a past/different edition.
# FOOTBALL_DATA_SEASON=2026

# Alternative provider: API-Football (api-football.com / RapidAPI). Server-side only.
# Only required when FOOTBALL_PROVIDER=api-football.
FOOTBALL_API_KEY=

# Optional: protects the /api/sync and scoring cron endpoints from public calls.
# Vercel Cron sends this as the Authorization: Bearer <CRON_SECRET> header.
CRON_SECRET=
